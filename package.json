{
  "name": "juicebag-mail",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build": "pnpm -r build",
    "check": "pnpm -r check",
    "dev:service": "dotenv -e .env.service -- pnpm --filter @juicebag-mail/service-api dev",
    "dev:agent": "dotenv -e .env.agent -- pnpm --filter @juicebag-mail/agent-api dev",
    "dev:ui": "dotenv -e .env.agent -e .env.service -- pnpm --filter @juicebag-mail/demo-ui dev",
    "dev:mcp": "dotenv -e .env.agent pnpm --filter @juicebag-mail/juicebag-mcp dev"
  },
  "devDependencies": {
    "dotenv-cli": "^11.0.0"
  }
}
